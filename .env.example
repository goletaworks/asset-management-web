# Required. JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters and not the literal placeholder.
JWT_SECRET=

# MongoDB connection string. Required when db-config.json targets mongodb.
MONGODB_URI=mongodb://localhost:27017/asmgt

# Node environment. Use "production" in deployed environments to set secure cookies.
NODE_ENV=development

# HTTP listening port. Defaults to 3000 when unset.
PORT=3000

# Optional. SMTP transport URL used for access-request emails. When unset, emails fall back to console output.
SMTP_URL=

# Optional. Override for the data folder where Excel workbooks live. Defaults to ./data.
KASMGT_DATA_DIR=

# Optional. Disables the chatbot-related UI/integrations when set to "true".
CHATBOT_DISABLED=false
